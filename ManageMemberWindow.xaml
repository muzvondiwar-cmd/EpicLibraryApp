<Window x:Class="EpicLibraryApp.ManageMembersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}"
        Title="Manage Library Members" Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Loaded="Window_Loaded">

    <Grid Background="#F4F6F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Margin="20" Padding="20" CornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp1">
            <StackPanel>
                <TextBlock Text="Register New Member" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,20"/>

                <TextBox x:Name="NewMemberNameBox" materialDesign:HintAssist.Hint="Full Name" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,20" FontSize="15"/>
                
                <ComboBox x:Name="NewMemberRoleBox" materialDesign:HintAssist.Hint="Select Role" Style="{StaticResource MaterialDesignFloatingHintComboBox}" Margin="0,0,0,30" FontSize="15">
                    <ComboBoxItem Content="Student" IsSelected="True"/>
                    <ComboBoxItem Content="Staff"/>
                </ComboBox>

                <Button Content="REGISTER MEMBER" Click="RegisterMember_Click" Background="#7E57C2" BorderBrush="#7E57C2" Height="45" materialDesign:ButtonAssist.CornerRadius="8"/>

                <TextBlock x:Name="RegisterStatusText" Text="" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="0,20,20,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Member Directory" FontSize="20" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>

                <DataGrid x:Name="MembersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" materialDesign:DataGridAssist.CornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>