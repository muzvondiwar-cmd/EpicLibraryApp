<Window x:Class="EpicLibraryApp.IssueReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}"
        Title="Issue &amp; Return Books" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Loaded="Window_Loaded">

    <Grid Background="#F4F6F9">
        <TabControl materialDesign:ColorZoneAssist.Mode="PrimaryMid" Margin="10">
            
            <TabItem Header="ISSUE BOOK">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <materialDesign:PackIcon Kind="AccountTie" Width="30" Height="30" Foreground="#7E57C2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="MemberComboBox" materialDesign:HintAssist.Hint="Select Borrower" Width="300" Style="{StaticResource MaterialDesignFloatingHintComboBox}" FontSize="16" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>

                    <DataGrid x:Name="AvailableBooksGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column" Background="White" materialDesign:DataGridAssist.CornerRadius="8" Margin="0,0,0,20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Book Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="*"/>
                            <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="IssueStatusText" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="ISSUE SELECTED BOOK" Click="IssueBook_Click" Background="#7E57C2" BorderBrush="#7E57C2" Height="45" Width="200" materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="RETURN BOOK">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Select an Active Loan to Return" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>

                    <DataGrid x:Name="ActiveLoansGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column" Background="White" materialDesign:DataGridAssist.CornerRadius="8" Margin="0,0,0,20">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Borrower" Binding="{Binding Member.Name}" Width="*"/>
                            <DataGridTextColumn Header="Book Title" Binding="{Binding Book.Title}" Width="*"/>
                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat=d}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="ReturnStatusText" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="RETURN SELECTED BOOK" Click="ReturnBook_Click" Background="#26A69A" BorderBrush="#26A69A" Height="45" Width="220" materialDesign:ButtonAssist.CornerRadius="8"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</Window>