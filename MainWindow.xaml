<Window x:Class="EpicLibraryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}"
        Title="Africa University Engineering Library Dashboard" Height="720" Width="1150"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E2C">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/> 
                    <RowDefinition Height="Auto"/> 
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,30,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                        <materialDesign:PackIcon Kind="Bookshelf" Width="35" Height="35" Foreground="#7E57C2" Margin="0,0,10,0"/>
                        <TextBlock Text="Eng-Library" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="50" HorizontalContentAlignment="Left" Padding="30,0,0,0" Margin="10,0,10,5">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" Margin="0,0,15,0"/>
                            <TextBlock Text="Dashboard" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BrowseCatalogButton" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#A0A0B0" Height="50" HorizontalContentAlignment="Left" Padding="30,0,0,0" Margin="10,0,10,5" Click="OpenCatalog_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookSearch" Width="20" Height="20" Margin="0,0,15,0"/>
                            <TextBlock Text="Browse Catalog" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="IssueReturnButton" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#A0A0B0" Height="50" HorizontalContentAlignment="Left" Padding="30,0,0,0" Margin="10,0,10,5" Click="OpenIssueReturn_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookSync" Width="20" Height="20" Margin="0,0,15,0"/>
                            <TextBlock Text="Issue / Return" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ManageMembersButton" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#A0A0B0" Height="50" HorizontalContentAlignment="Left" Padding="30,0,0,0" Margin="10,0,10,5" Click="OpenMembers_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20" Margin="0,0,15,0"/>
                            <TextBlock Text="Members" FontSize="16"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Grid.Row="1" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#E53935" Height="50" HorizontalContentAlignment="Left" Padding="30,0,0,0" Margin="10,0,10,20" Click="LogoutButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout" Width="20" Height="20" Margin="0,0,15,0"/>
                        <TextBlock Text="Logout" FontSize="16"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F4F6F9" Padding="40">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock x:Name="WelcomeMessageText" Text="Welcome back..." FontSize="32" FontWeight="Light" Foreground="#333333"/>
                    <TextBlock x:Name="UserRoleText" Text="Loading your library dashboard..." FontSize="15" Foreground="#777777" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,30">
                    <materialDesign:Card Width="250" Height="120" Margin="0,0,20,0" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel Margin="20">
                            <TextBlock Text="TOTAL BOOKS" FontSize="12" FontWeight="SemiBold" Foreground="#888888" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TotalBooksText" Text="..." FontSize="38" FontWeight="Bold" Foreground="#7E57C2"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Width="250" Height="120" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel Margin="20">
                            <TextBlock Text="ACTIVE LOANS" FontSize="12" FontWeight="SemiBold" Foreground="#888888" Margin="0,0,0,10"/>
                            <TextBlock x:Name="ActiveLoansText" Text="..." FontSize="38" FontWeight="Bold" Foreground="#26A69A"/>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="My Active Loans" FontSize="20" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    
                    <DataGrid x:Name="MyBooksGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" materialDesign:DataGridAssist.CornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Book Title" Binding="{Binding Book.Title}" Width="*"/>
                            <DataGridTextColumn Header="Author" Binding="{Binding Book.Author}" Width="*"/>
                            <DataGridTextColumn Header="Borrowed On" Binding="{Binding IssueDate, StringFormat=d}" Width="150"/>
                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat=d}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                
            </Grid>
        </Border>
    </Grid>
</Window>