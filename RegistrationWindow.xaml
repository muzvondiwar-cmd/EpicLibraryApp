<Window x:Class="EpicLibraryApp.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}"
        Title="Student Registration" Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">

    <Grid Background="#1E1E2C">
        <materialDesign:Card Margin="30" UniformCornerRadius="10" Padding="30" VerticalAlignment="Center" Background="White">
            <StackPanel>
                <materialDesign:PackIcon Kind="AccountPlus" Width="50" Height="50" HorizontalAlignment="Center" Foreground="#26A69A" Margin="0,0,0,10"/>
                <TextBlock Text="Student Registration" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#333333"/>
                <TextBlock Text="Africa University Engineering Library" FontSize="13" Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,30" TextAlignment="Center"/>

                <TextBox x:Name="FullNameBox" materialDesign:HintAssist.Hint="Full Name" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,20" Foreground="#333333"/>

                <TextBox x:Name="StudentIdBox" materialDesign:HintAssist.Hint="Student ID (e.g., 250591)" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,20" Foreground="#333333"/>

                <PasswordBox x:Name="PasswordBox" materialDesign:HintAssist.Hint="Create a Password" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" Margin="0,0,0,30" Foreground="#333333"/>

                <TextBlock x:Name="StatusMessage" Text="" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15" Visibility="Collapsed"/>

                <Button Content="REGISTER ACCOUNT" Height="45" Click="RegisterButton_Click" Background="#26A69A" BorderBrush="#26A69A" Foreground="White" materialDesign:ButtonAssist.CornerRadius="8" Margin="0,0,0,15"/>

                <Button Content="BACK TO LOGIN" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#7E57C2" Click="BackToLogin_Click" HorizontalAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>